        "ref": "main"
      },
      {
        "name": "galexie",
        "repo": "stellar/stellar-galexie",
        "ref": "galexie-v26.1.0"
      }
    ],
    "tests": {
      "continue-on-error": false,
      "additional-tests": [
        {
          "arch": "amd64",
          "network": "pubnet",
          "enable": "core,rpc,horizon"
        }
